# {{ ansible_managed }}
# Dovecot SSL configuration

## Use system Dovecot PKI certificates by default (configurable via vars)
ssl = required
ssl_cert = <{{ dovecot_cert | default(mail_ssl_dir + '/server.crt') }}
ssl_key  = <{{ dovecot_key  | default(mail_ssl_dir + '/server.key') }}
ssl_ca   = <{{ dovecot_ca   | default(mail_ssl_dir + '/ca.crt') }}

# SSL protocols and ciphers
ssl_min_protocol = TLSv1.2
ssl_prefer_server_ciphers = yes
ssl_cipher_list = ALL:!ADH:!LOW:!SSLv2:!SSLv3:!EXP:!aNULL:+HIGH:+MEDIUM